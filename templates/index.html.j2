<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ site_title }}</title>
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="apple-touch-icon" href="apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>{{ css | safe }}</style>
</head>
<body>
  <header class="topbar">
    <a class="logo" href="index.html" aria-label="HMCC Sermon Guides"><img src="hmcc-logo.svg" alt="HMCC" width="110" height="43"></a>
    <a class="nav-link" href="index.html">All Guides</a>
  </header>

  <main class="wrap">
    <section class="index-hero">
      <h1>{{ site_title }}</h1>
      <div class="tag">Weekly guides for personal study &amp; small groups</div>
    </section>

    <ul class="guide-list">
      {% for g in guides %}
      <li>
        <a href="{{ g.slug }}.html">
          <span class="g-series">{{ g.series }}</span>
          <span class="g-part">{{ g.part }}</span>
          {% if g.date %}<span class="g-date">{{ g.date }}</span>{% endif %}
        </a>
      </li>
      {% endfor %}
    </ul>
  </main>

  {% include "_footer.html.j2" %}
</body>
</html>
