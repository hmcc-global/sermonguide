# Copy to .env.local and fill in. NONE of these are prefixed NEXT_PUBLIC_ — they stay server-side only.

# Shared passcode leaders type once to create/publish guides (/create).
APP_PASSCODE=change-me

# Separate, higher-privilege passcode for the manage view (/manage): edit + delete.
# Give this only to admins — a different audience than APP_PASSCODE.
ADMIN_PASSCODE=change-me-too

# Gemini API key (free tier ok). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fine-grained GitHub PAT scoped to the sermonguide repo.
# Permissions: Contents = Read and write, Metadata = Read-only.
GITHUB_TOKEN=
GITHUB_OWNER=hmcc-global
GITHUB_REPO=sermonguide
GITHUB_BRANCH=main

# Phase 2 (audio) only — created automatically when you add a Vercel Blob store.
# BLOB_READ_WRITE_TOKEN=

# Public base URL of the guide site (used for the "live" link the studio shows).
# Defaults to the github.io Pages URL if unset.
SITE_URL=https://sermonguide-delta.vercel.app

# Optional at build time: lets the guide pages fetch ESV passages for guides
# that only have a scripture reference (not inline text). Same key the Pages
# build uses. Guides with inline scripture_passage don't need it.
# ESV_API_KEY=
